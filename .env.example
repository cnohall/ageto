# Supabase (Settings → API in your Supabase project)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Helius (helius.dev → API Keys)
HELIUS_API_KEY=your-helius-api-key
HELIUS_WEBHOOK_SECRET=your-webhook-secret

# Solana
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-helius-api-key
TREASURY_WALLET=your-solana-wallet-address-for-usdc

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo mode (optional — enables "Try Demo" on the tax page)
DEMO_API_KEY=demo-secret-key-change-this
DEMO_WALLET=your-demo-solana-wallet-address
NEXT_PUBLIC_DEMO_API_KEY=demo-secret-key-change-this
NEXT_PUBLIC_DEMO_WALLET=your-demo-solana-wallet-address
